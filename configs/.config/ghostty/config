font-family = PlemolJP Console NF
font-size = 14
font-thicken = true

cursor-style = block
cursor-style-blink = false

window-padding-x = 8
window-padding-y = 8
theme = tokyonight

quick-terminal-size = 40%

window-save-state = always
macos-option-as-alt = true
macos-titlebar-style = tabs

keybind = clear

# general
keybind = super+w=close_surface
keybind = super+q=quit
keybind = super+z=undo
keybind = super+shift+z=redo
keybind = super+shift+i=inspector:toggle
keybind = super+shift+comma=reload_config
keybind = global:super+backquote=toggle_quick_terminal

# font size
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+0=reset_font_size

# copy & paste
keybind = super+c=copy_to_clipboard
keybind = copy=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = paste=paste_from_clipboard

# split
keybind = super+j>minus=new_split:down
keybind = super+j>backslash=new_split:right
keybind = super+j>h=goto_split:left
keybind = super+j>j=goto_split:down
keybind = super+j>k=goto_split:up
keybind = super+j>l=goto_split:right
keybind = super+j>shift+period=resize_split:up,10
keybind = super+j>shift+comma=resize_split:down,10
keybind = super+j>z=toggle_split_zoom

# tab
keybind = super+t=new_tab
keybind = ctrl+tab=next_tab
